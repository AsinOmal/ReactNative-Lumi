{
  "name": "lumi-functions",
  "version": "1.0.0",
  "private": true,
  "engines": { "node": "20" },
  "main": "lib/index.js",
  "scripts": {
    "build":   "tsc",
    "watch":   "tsc --watch",
    "serve":   "npm run build && firebase emulators:start --only functions",
    "deploy":  "firebase deploy --only functions",
    "lint":    "eslint --ext .ts src/"
  },
  "dependencies": {
    "firebase-admin":    "^12.0.0",
    "firebase-functions": "^6.0.0"
  },
  "devDependencies": {
    "typescript":              "^5.0.0",
    "@types/node":             "^20.0.0",
    "firebase-functions-test": "^3.0.0"
  }
}
