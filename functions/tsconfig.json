{
  "compilerOptions": {
    "module":           "commonjs",
    "moduleResolution": "node",
    "noImplicitReturns": true,
    "noUnusedLocals":   true,
    "outDir":           "lib",
    "sourceMap":        true,
    "strict":           true,
    "target":           "ES2022",
    "lib":              ["ES2022"],
    "skipLibCheck":     true
  },
  "compileOnSave": true,
  "include": ["src"]
}
