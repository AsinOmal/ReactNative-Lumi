rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Admin users have the custom claim `admin: true` set via Firebase Admin SDK.
    // The admin panel gate (useAdminAuth.ts) also enforces this client-side.
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Reject writes where the value is not a non-empty string under 200 chars.
    function isValidString(val) {
      return val is string && val.size() > 0 && val.size() <= 200;
    }

    // ── Admin config ──────────────────────────────────────────────────────────
    // Feature flags, game constants, banner, moderation — mobile reads at boot.
    match /adminConfig/{document} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Broadcasts live at /adminConfig/notifications/broadcasts/{id} (a
    // subcollection of the 'notifications' doc). Must be a top-level rule
    // because the parent /adminConfig/{document} rule only governs that single
    // doc layer — nested matches would require a different actual data shape.
    match /adminConfig/notifications/broadcasts/{broadcastId} {
      allow read, write: if isAdmin();
    }

    // ── Packs ─────────────────────────────────────────────────────────────────
    match /packs/{packId} {
      allow read: if isSignedIn() && (resource.data.isPublished == true || isAdmin());
      allow write: if isAdmin();
    }

    // ── 3D model registry ─────────────────────────────────────────────────────
    match /adminModels/{modelId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── User profile ──────────────────────────────────────────────────────────
    // Users own their profile. Admins can read for moderation but not write
    // (admin writes go through the Admin SDK from Cloud Functions).
    // The `suspended` field is admin-managed — users cannot alter it.
    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid)
        && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['suspended', 'fcmToken', 'createdAt']);
    }

    // ── User subcollections ───────────────────────────────────────────────────
    match /users/{uid}/savedWords/{word} {
      allow read, delete: if isOwner(uid);
      allow create: if isOwner(uid)
        && isValidString(request.resource.data.word)
        // Word must be a safe identifier: letters, hyphens, apostrophes only.
        && request.resource.data.word.matches('^[a-zA-Z\'-]{1,50}$')
        // Document ID must match the word field to prevent path injection.
        && word == request.resource.data.word;
      // No updates — words are created or deleted, never mutated.
    }

    match /users/{uid}/achievements/{achievementId} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid);
      // Achievements are append-only — no updates or deletes from the client.
    }

    match /users/{uid}/gameProgress/{progressId} {
      allow read, write: if isOwner(uid);
    }

    match /users/{uid}/activityLog/{logId} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid)
        && isValidString(request.resource.data.word)
        && request.resource.data.get('flagged', false) is bool;
      // No update or delete from client — logs are append-only (anti-tampering).
    }

    match /users/{uid}/parentSettings/{document=**} {
      allow read, write: if isOwner(uid);
    }

    match /users/{uid}/screenTime/{document=**} {
      allow read, write: if isOwner(uid);
    }

    // ── Collection group rules (admin analytics) ──────────────────────────────
    // Firestore requires explicit {path=**} rules for collectionGroup() queries.
    // The {subcollection=**} wildcard under /users/{uid} does NOT satisfy them.
    match /{path=**}/savedWords/{wordId} {
      allow read: if isAdmin();
    }

    match /{path=**}/achievements/{achievementId} {
      allow read: if isAdmin();
    }

    match /{path=**}/gameProgress/{progressId} {
      allow read: if isAdmin();
    }

    match /{path=**}/activityLog/{logId} {
      allow read: if isAdmin();
      allow update: if isAdmin(); // reviewEvent marks flagged entries as reviewed
    }

    // Admin analytics: aggregate screen-time across all users via collectionGroup.
    // The /users/{uid}/screenTime/* rule is owner-only, so this top-level rule
    // is required for the admin's leaderboard / trend queries.
    match /{path=**}/screenTime/{day} {
      allow read: if isAdmin();
    }

    // ── Community Wishlist ────────────────────────────────────────────────────
    // Any signed-in user can create/increment their word wish (merge writes only).
    // Admins can read the full collection to see most-requested words.
    match /wishlist/{wordId} {
      allow create, update: if request.auth != null;
      allow read, write: if isAdmin();
    }

    // ── Purchases ─────────────────────────────────────────────────────────────
    match /users/{uid}/purchases/{packId} {
      allow read, create: if request.auth != null && request.auth.uid == uid;
      allow read, write: if isAdmin();
    }
    match /{path=**}/purchases/{packId} {
      allow read: if isAdmin();
    }

    match /{path=**}/hazardEvents/{eventId} {
      allow read: if isAdmin();
    }

    // ── Feedback ──────────────────────────────────────────────────────────────
    // Any signed-in user can submit; only admins can read/manage.
    match /feedback/{feedbackId} {
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.email == request.auth.token.email
        && isValidString(request.resource.data.message)
        && request.resource.data.get('isRead', false) == false
        && !request.resource.data.keys().hasAny(['isModerated', 'reviewedAt']);
      allow read, update, delete: if isAdmin();
    }
  }
}
